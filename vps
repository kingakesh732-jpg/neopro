#!/bin/bash

# NeoPlayz Clean Master Script (Jishnu Logic - No Animation)

# Basic Colors
GREEN='\e[0;32m'
CYAN='\e[0;36m'
YELLOW='\e[1;33m'
WHITE='\e[0;37m'
NC='\e[0m'

# RAW BASE URL
BASE="https://raw.githubusercontent.com/kingakesh732-jpg/neopro/main"

clear

# Simple Header
echo -e "${CYAN}====================================================${NC}"
echo -e "          NEOPLAYZ VPS MANAGEMENT SYSTEM           "
echo -e "${CYAN}====================================================${NC}"

main_menu() {
    echo -e "\n${YELLOW}MAIN MENU${NC}"
    echo -e "A) Panel (Pterodactyl/Air-Link)"
    echo -e "B) Vps Maker (GitHub/IDX/Real)"
    echo -e "C) Tools (Wings/Cloudflare/DB)"
    echo -e "D) System Edit"
    echo -e "E) Exit"
    echo -e "${CYAN}----------------------------------------------------${NC}"
    read -p "Select Option: " opt

    case $opt in
        A|a) panel_menu ;;
        B|b) vps_menu ;;
        C|c) tools_menu ;;
        E|e) exit 0 ;;
        *) main_menu ;;
    esac
}

panel_menu() {
    clear
    echo -e "${GREEN}PANELS MENU${NC}"
    echo -e "1) Pterodactyl Panel"
    echo -e "2) Air-Link Panel"
    echo -e "3) Back"
    read -p "Choose: " p_opt
    case $p_opt in
        1) bash <(curl -sL https://pterodactyl-installer.se) ;;
        2) sudo apt update && sudo apt install docker.io -y ;;
        3) main_menu ;;
    esac
}

vps_menu() {
    clear
    echo -e "${GREEN}VPS MAKER MENU${NC}"
    echo -e "1) GitHub VPS Maker"
    echo -e "2) IDX Tool Setup"
    echo -e "3) IDX VPS Maker"
    echo -e "4) Real VPS (Any + KVM)"
    echo -e "5) Back"
    read -p "Choose: " v_opt
    case $v_opt in
        5) main_menu ;;
        *) echo "Executing..."; sleep 1; main_menu ;;
    esac
}

tools_menu() {
    clear
    echo -e "${GREEN}TOOLS MENU${NC}"
    echo -e "1) Panel Installation"
    echo -e "2) Wings Installation"
    echo -e "3) Uninstall Tools"
    echo -e "4) Blueprint+Theme"
    echo -e "5) Cloudflare Setup"
    echo -e "6) System Information"
    echo -e "7) Tailscale"
    echo -e "8) Database Setup"
    echo -e "0) Back"
    read -p "Choose: " t_opt
    case $t_opt in
        0) main_menu ;;
        *) echo "Running..."; sleep 1; main_menu ;;
    esac
}

main_menu
